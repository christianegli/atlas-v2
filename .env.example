# ─── LLM ──────────────────────────────────────────────────────────────────────
# Option A: Direct Anthropic API
ANTHROPIC_API_KEY=sk-ant-...

# Option B: Local proxy (OpenAI-compatible, e.g. LiteLLM or claude-proxy)
# If set, takes precedence over ANTHROPIC_API_KEY
# PROXY_BASE_URL=http://localhost:8642/v1
# PROXY_API_KEY=sk-proxy-local-dummy

# Model to use (default: claude-sonnet-4-6)
MODEL_ID=claude-sonnet-4-6

# ─── Telegram ─────────────────────────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# ─── Ollama (subconscious + embeddings) ───────────────────────────────────────
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=qwen3.5:9b
OLLAMA_EMBED_MODEL=nomic-embed-text

# ─── Storage ──────────────────────────────────────────────────────────────────
# Paths relative to cwd, or absolute
DB_PATH=./data/atlas.db
MIND_PATH=.

# ─── Limits ───────────────────────────────────────────────────────────────────
DAILY_TOKEN_BUDGET=500000
CONTEXT_TOKEN_BUDGET=30000
